# Copy to .env and fill in values
# cp .env.example .env

# IMPORTANT: set this to your username so your docker compose project is isolated
# from other users on the same machine (avoids service/port conflicts)
COMPOSE_PROJECT_NAME=yourname

HF_TOKEN=hf_...

# Shared settings
CTX_SIZE=32768
GPU_MEM_UTIL=0.90

# Slot 1
MODEL_1=unsloth/Qwen3.5-4B-GGUF
